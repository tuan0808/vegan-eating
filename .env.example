#DATABASE_URL="file:./dev.db"
AUTH_SECRET=
AUTH_URL=https://veganeating.com

RESEND_API_KEY=
RESEND_AUDIENCE_ID=

MAINTENANCE_BYPASS_TOKEN=
NEWSDATA_API_KEY=

CRON_SECRET=

SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_BUCKET=veganeating-media
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=us-east-1
SPACES_PUBLIC_BASE=https://veganeating-media.nyc3.cdn.digitaloceanspaces.com

# Public origin, used for canonical URLs, Open Graph tags and the sitemap.
NEXT_PUBLIC_SITE_URL=https://veganeating.com
# CDN/Spaces base for relative media paths in JSON-LD + image URLs. Falls back
# to serving from /public when unset (fine for local dev).
NEXT_PUBLIC_MEDIA_BASE_URL=https://veganeating-media.nyc3.cdn.digitaloceanspaces.com

# --- Analytics ---
# Optional salt for the cookieless visitor hash. Falls back to NEXTAUTH_SECRET.
ANALYTICS_SALT=
# Google Search Console (powers the "Search queries & rankings" panel in the
# admin Analytics dashboard). Leave blank to keep that panel dormant. Setup
# steps are documented at the top of src/lib/search-console.ts.
GSC_SITE_URL=          # e.g. sc-domain:veganeating.com  OR  https://veganeating.com/
GSC_CLIENT_EMAIL=      # service-account email
GSC_PRIVATE_KEY=       # service-account private key (PEM; keep the \n escapes)

