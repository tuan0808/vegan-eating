// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // the POOL connection string
  directUrl = env("DIRECT_URL")    // the DIRECT cluster string (port 25060)
}

model Recipe {
  id          String    @id // slug
  slug        String    @unique
  title       String
  sourceUrl   String
  date        String
  description String
  recipeType  String
  author      String
  // SQLite has no array type, so list fields are stored as JSON strings
  views       Int       @default(0)
  courses     String    @default("[]")
  seasons     String    @default("[]")
  allergens   String    @default("[]")
  cuisines    String    @default("[]")
  prepTime    Int?
  cookTime    Int?
  readyIn     Int?
  servings    String    @default("")
  calories    Int?
  ingredients String    @default("[]")
  steps       String    @default("[]")
  image       String?
  gallery     String    @default("[]")
  comments    Comment[]
  bookmarks     Bookmark[]
  ratings       Rating[]
  shoppingItems ShoppingItem[]
  cookalong   String    @default("[]")
  ph          String
  sort        Int       @default(0)
  hidden      Boolean   @default(false)
  category    String    @default("")
  // --- AI image generation (gpt-image-2) ---
  imageBackup       String?                // previous/alternate hero — enables swap-back
  imagePending      String?                // freshly generated hero, awaiting review
  stepImages        String  @default("[]") // live per-step image keys, aligned to steps[]
  stepImagesPending String  @default("[]") // generated step images, awaiting review

  @@index([recipeType])
  @@index([sort])
}

model Article {
  id        Int       @id @default(autoincrement())
  slug      String    @unique
  title     String
  author    String    @default("vegor")
  sourceUrl String
  date      String
  image     String?
  views     Int       @default(0)
  body      String    @default("[]")
  tags      String    @default("[]")
  category  String    @default("")
  sort      Int       @default(0)
  hidden    Boolean   @default(false)
  gallery   String    @default("[]")
  comments  Comment[]

  @@index([sort])
}

// ======================== COPY FROM HERE ========================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String?
  name          String?
  avatarUrl     String?
  bio           String?
  // --- public profile, all opt-in ---
  location      String?
  website       String?
  showActivity  Boolean   @default(true) // show thread/post stats + recent threads on public profile
  emailVerified DateTime?
  signupIp      String?
  role          String    @default("MEMBER") // MEMBER | MODERATOR | ADMIN  (becomes an enum on Postgres)
  banned        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  onboardedAt   DateTime? // set when they read the welcome thread; gates posting

  emailTokens EmailVerificationToken[]
  comments    Comment[]
  threads     Thread[]
  posts       Post[]

  // --- direct messaging ---
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  contactReplies  ContactReply[]
  veganizeRequests VeganizeRequest[]

  // --- recipe interactions ---
  bookmarks     Bookmark[]
  ratings       Rating[]
  shoppingItems ShoppingItem[]
  contactMessages ContactMessage[]

  @@index([signupIp])
}

// Top level: General, Vegan, Vegetarians, Around the World, Help

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  position    Int      @default(0) // controls display order
  createdAt   DateTime @default(now())

  forums Forum[]
}

// Sub-category / board: News, Introductions, Recipes, Guides, Rules, etc.
// Names repeat across categories (Vegan→Recipes and Vegetarians→Recipes),
// so the slug is only unique *within* a category and we route by both.

model Forum {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  slug        String
  description String?
  postMinRole String   @default("MEMBER") // MEMBER | MODERATOR | ADMIN — min role to post here
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  threads  Thread[]

  @@unique([categoryId, slug])
  @@index([categoryId])
}

// A topic. Its opening message is the first Post (everything is a Post),
// which keeps editing/quoting uniform later.

model Thread {
  id         String   @id @default(cuid())
  forumId    String
  authorId   String
  title      String
  tag        String?
  slug       String   @unique
  pinned     Boolean  @default(false)
  locked     Boolean  @default(false)
  viewCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastPostAt DateTime @default(now()) // denormalised for cheap "latest activity" sorting

  forum  Forum  @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])
  posts  Post[]

  @@index([forumId, lastPostAt])
}

model Post {
  id        String    @id @default(cuid())
  threadId  String
  authorId  String
  body      String
  status    String    @default("APPROVED") // APPROVED | PENDING
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  editedAt  DateTime?
  ipAddress String?
  userAgent String?

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([threadId, createdAt])
  @@index([status])
}

model Setting {
  key   String @id
  value String
}

model Comment {
  id         String @id @default(cuid())
  body       String
  authorName String
  status     String @default("APPROVED") // APPROVED | HIDDEN | SPAM
  rating     Int?   // 1..5 when this comment is also a recipe review; null = plain comment

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ipAddress String? // captured from proxy headers for the audit trail
  userAgent String?

  recipeId  String?
  recipe    Recipe?  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  articleId Int?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  newsArticleId String?
  newsArticle   NewsArticle? @relation(fields: [newsArticleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([recipeId])
  @@index([articleId])
  @@index([parentId])
  @@index([status])
  @@index([createdAt])
  @@index([newsArticleId])
}

model BlockedIp {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Direct messages between two users. Flat table — a "conversation" is just
// the set of rows between two userIds, grouped in the query layer. Keeps the
// inbox simple; no separate Conversation table to maintain.
model Message {
  id          String    @id @default(cuid())
  senderId    String
  recipientId String
  body        String
  readAt      DateTime? // null = unread by the recipient
  createdAt   DateTime  @default(now())

  sender    User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt]) // unread badge
  @@index([senderId])
  @@index([createdAt])
}

model ItemView {
  id       String   @id @default(cuid())
  kind     String   // "recipe" | "article"
  itemId   String   // recipe.id (cuid) or article.id as a string
  userId   String   // user.id, or email as a fallback key
  userName String   @default("")
  viewedAt DateTime @default(now())

  @@unique([kind, itemId, userId])
  @@index([kind, itemId])
}

model RecipeSubmission {
  id         String   @id @default(cuid())
  title      String
  dietType   String   // "VEGAN" | "VEGETARIAN"
  ingredients String  // raw multiline text, reviewer maps to a real Recipe
  method     String
  prepMin    Int?
  cookMin    Int?
  readyMin   Int?
  images     String   @default("[]")  // JSON array of /uploads/... paths
  status     String   @default("PENDING")
  userId     String?  // plain field, no relation — keeps the change to one model
  authorName String?
  createdAt  DateTime @default(now())
  threadSlug String?  // set on approval — links back to the created thread
  reviewedAt DateTime?
  recipeSlug String?  // set when promoted into the Recipe library
  source     String  @default("MANUAL") // "MANUAL" | "VEGANIZER"
  veganizeRequestId String?

}

// ======================== RECIPE INTERACTIONS ========================

// Saved / bookmarked recipes. One row per (user, recipe).
model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([userId, createdAt])
}

// A star rating (1–5) with an optional written review. One per (user, recipe),
// editable — re-rating updates the existing row.
model Rating {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  score     Int // 1..5
  review    String? // optional written review
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([recipeId])
  @@index([userId, createdAt])
}

// One line on a member's shopping list. Items carry the recipe they came from
// (denormalised title too) so the list groups nicely and survives recipe edits.
// recipeId null = a manually added item.
model ShoppingItem {
  id          String   @id @default(cuid())
  userId      String
  text        String
  recipeId    String?
  recipeTitle String?
  checked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([userId, checked])
  @@index([userId, recipeId])
}

model NewsArticle {
  id          String   @id @default(cuid())
  externalId  String   @unique
  slug        String   @unique
  title       String
  description String   @default("")
  link        String
  image       String?
  source      String   @default("")
  pubDate     DateTime
  categories  String   @default("[]")
  content     String   @default("")   // ← the missing field (full article body)
  comments    Comment[]
  hidden      Boolean  @default(false)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  dupeOf      String?   // slug of the kept original when sync auto-hides this as an exact-title duplicate

  @@index([dupeOf])
  @@index([pubDate])
  @@index([hidden])
}

model ContactMessage {
  id        String   @id @default(cuid())
  userId    String              // the signed-in member who sent it
  name      String              // display name at send time (prefilled, editable)
  category  String              // "GENERAL" | "SUPPORT" | "RECIPES"
  body      String
  status    String   @default("OPEN") // "OPEN" | "HANDLED"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies ContactReply[]

  @@index([status])
  @@index([createdAt])
}
model ContactReply {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  ticket ContactMessage @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}
model VeganizeRequest {
  id        String   @id @default(cuid())
  userId    String
  inputHash String
  input     String   // raw pasted recipe (for admin review + abuse detection)
  output    String   // cached JSON result we returned
  cached    Boolean  @default(false)
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([inputHash])
}